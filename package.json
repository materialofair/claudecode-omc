{
  "name": "claudecode-omc",
  "version": "5.1.0",
  "description": "Claude Code harness — best-practice skills, agents, hooks, and configs from multiple sources",
  "bin": {
    "omc-manage": "bin/omc-manage.js"
  },
  "files": [
    "bin",
    "src",
    ".local",
    "bundled",
    "scripts",
    "templates",
    "README.md"
  ],
  "scripts": {
    "setup": "node bin/omc-manage.js setup",
    "doctor": "node bin/omc-manage.js doctor",
    "source:list": "node bin/omc-manage.js source list",
    "source:sync": "node bin/omc-manage.js source sync",
    "source:status": "node bin/omc-manage.js source status",
    "skill:list": "node bin/omc-manage.js skill list",
    "skill:conflicts": "node bin/omc-manage.js skill conflicts",
    "bundle": "bash scripts/bundle-upstream.sh",
    "prepublishOnly": "bash scripts/bundle-upstream.sh",
    "postinstall": "node scripts/post-install-message.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude-code",
    "oh-my-claudecode",
    "superpowers",
    "skills",
    "agents",
    "hooks",
    "harness",
    "multi-source",
    "ai-agent",
    "best-practices"
  ],
  "license": "MIT"
}
